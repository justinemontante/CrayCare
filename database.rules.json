{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin' || root.child('users').child(auth.uid).child('profile').child('ownerUid').val() === $uid)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')",
        "notifications": {
          "$notifId": {
            "readBy": {
              "$readerUid": {
                ".write": "auth != null && auth.uid === $readerUid && root.child('users').child(auth.uid).child('profile').child('ownerUid').val() === $uid"
              }
            }
          }
        }
      }
    },
    "tank_data": {
      "$ownerUid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $ownerUid && root.child('users').child(auth.uid).child('profile').child('role').val() === 'owner'"
      }
    },
    "ml_predictions": {
      ".read": "auth != null",
      ".write": true
    },
    "sensor_readings": {
      ".read": "auth != null",
      ".write": true
    },
    "notifications": {
      ".read": "auth != null",
      ".write": true
    },
    "feeder": {
      ".read": "auth != null",
      ".write": true
    },
    "devices": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "system": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}

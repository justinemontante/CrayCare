{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "notifications": {
          "$notifId": {
            "readBy": {
              "$readerUid": {
                ".write": "auth != null && auth.uid === $readerUid"
              }
            }
          }
        }
      }
    },
    "production": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "tank_data": {
      "$ownerUid": {
        ".read": "auth != null && auth.uid === $ownerUid",
        ".write": "auth != null && auth.uid === $ownerUid"
      }
    },
    "ml_predictions": {
      ".read": true,
      ".write": true
    },
    "sensor_readings": {
      // ESP32 devices write sensor data; authenticated users can read it.
      // If the ESP uses anonymous auth, keep .write as "auth != null";
      // otherwise restrict to a service account via custom claims.
      ".read": "auth != null",
      ".write": true
    },
    // The top-level 'notifications' node is no longer used by the app.
    // All notifications are stored under users/{uid}/notifications.
    // This rule is kept for backward compatibility but restricted.
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "feeder": {
      ".read": "auth != null",
      ".write": true
    },
    "devices": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "system": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Role helpers ────────────────────────────────────────────────
    // An 'admin' role can only be set directly on a users/{uid} document
    // from the Firestore console — there is no app code path that lets a
    // user grant themselves admin.
    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && myProfile().role == 'admin';
    }

    function deviceOwnerUid() {
      return exists(/databases/$(database)/documents/config/deviceOwner)
        ? get(/databases/$(database)/documents/config/deviceOwner).data.ownerUid
        : null;
    }

    // The assigned owner of the single shared device.
    function isDeviceOwner() {
      return isSignedIn() && request.auth.uid == deviceOwnerUid();
    }

    // Users can read/write their own profile; admins can read/write any
    // profile (needed for the admin screen: disable accounts, change
    // roles, assign the device owner).
    match /users/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Users can only read/write their own notification prefs
    match /notifPrefs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /batches/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /sampling/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /mortality/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /activities/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /harvests/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Per-user threshold docs (document id == uid) keep working as
    // before. config/deviceOwner is a special admin-only doc (document id
    // 'deviceOwner' never equals a real uid, so isAdmin() is the only way
    // in) that says which owner the single physical device belongs to.
    match /config/{document} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == document || isAdmin());
    }

    match /notifications/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /notifMarkers/{doc} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /migration/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Only the assigned device owner (config/deviceOwner.ownerUid) or an
    // admin can read live/historical readings. The ESP hardware itself
    // writes unauthenticated, so create/update stay open — that part of
    // the pipeline is unchanged.
    match /sensorReadings/{doc} {
      allow read: if isAdmin() || isDeviceOwner();
      allow create, update: if true;
    }

    match /sensorReadings/history/{date}/{doc} {
      allow read: if isAdmin() || isDeviceOwner();
      allow create, update: if true;
    }

    match /feederSchedules/{doc} {
      allow read, write: if request.auth != null;
    }

    match /feederLogs/{doc} {
      allow read, write: if request.auth != null;
    }

    match /feederCommands/{doc} {
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    match /feederStatus/{doc} {
      allow read, write: if request.auth != null;
    }

    match /feederDispatched/{doc} {
      allow read, write: if request.auth != null;
    }

    match /deviceModes/{doc} {
      allow read, write: if request.auth != null;
    }

    match /deviceLogs/{doc} {
      allow read, create: if request.auth != null;
    }

    match /mlPredictions/{doc} {
      allow read: if request.auth != null;
      allow create, update: if true;
    }

    match /healthRisk/{doc} {
      allow read: if request.auth != null;
      allow create, update: if true;
    }
  }
}
